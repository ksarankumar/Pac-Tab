{
  "manifest_version": 3,
  "name": "PacTab — Munch the clutter, save the RAM",
  "version": "2.0.0",
  "description": "Munch tab clutter and free your RAM: live dashboard, smart auto-limits, duplicate cleanup, domain insights, and protected tabs.",
  "permissions": ["tabs", "storage", "notifications"],
  "background": {
    "service_worker": "service-worker.js"
  },
  "action": {
    "default_popup": "dashboard.html",
    "default_title": "PacTab — Munch the clutter, save the RAM",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "settings.html",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "host_permissions": ["<all_urls>"]
}
